# API Configuration
# Si vas a correr el proxy-backend con Node (npm start) usa 3001
# Si vas a correrlo con Docker (docker-compose) usa 3002
VITE_API_BASE_URL=http://localhost:3001

# External APIs
# Nota: La API Key de SIISA se inyecta en el proxy-backend; no es necesaria en el frontend
VITE_SIISA_API_KEY=tu_api_key_aqui
VITE_TOKEN_API_URL=http://localhost:8081

# Environment
VITE_ENV=development

# Debug
VITE_DEBUG=true
